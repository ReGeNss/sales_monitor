{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "<rootDir>/../tsconfig.json"
    }]
  },
  "moduleNameMapper": {
    "@sales-monitor/database": "<rootDir>/../../../packages/database/dist",
    "@sales-monitor/common": "<rootDir>/../../../packages/common/dist"
  }
}
